# Minimal static build module overrides (musl).
# Copied to Modules/Setup.local by Tools/build/build-minimal-musl.sh.
#
# Setup.stdlib.minimal.in already lists only kept modules; this file
# disables anything configure might still try to add.

*disabled*

# GPL-linked
readline
_gdbm
_dbm

